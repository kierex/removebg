{
  "name": "shareboost-pro",
  "version": "2.0.0",
  "description": "Professional automated Facebook post sharing platform with claymorphism UI and enhanced features",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "build": "npm run lint && npm test",
    "pm2:start": "pm2 start server.js --name shareboost-pro",
    "pm2:stop": "pm2 stop shareboost-pro",
    "pm2:restart": "pm2 restart shareboost-pro",
    "logs": "pm2 logs shareboost-pro",
    "monit": "pm2 monit"
  },
  "keywords": [
    "facebook",
    "automation",
    "sharing",
    "boost",
    "social-media",
    "express",
    "claymorphism"
  ],
  "author": "ShareBoost Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/shareboost-pro.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/shareboost-pro/issues"
  },
  "homepage": "https://github.com/yourusername/shareboost-pro#readme",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.11",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.52.0",
    "prettier": "^3.0.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "pm2": "^5.3.0",
    "cross-env": "^7.0.3"
  },
  "private": false,
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
      "no-async-promise-executor": "off"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "nodemonConfig": {
    "watch": ["server.js", "public"],
    "ignore": ["logs/*", "node_modules"],
    "ext": "js,json,html,css",
    "delay": 1000
  }
}